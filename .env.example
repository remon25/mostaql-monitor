# انسخ هذا الملف باسم .env وعدّل القيم حسب رغبتك

# رابط قائمة المشاريع
LISTING_URL=https://mostaql.com/projects?category=development&sort=latest

# كم صفحة نفحص في كل تشغيلة
PAGES_TO_SCAN=1

# الحد الأدنى للميزانية بالدولار
MIN_BUDGET=250

# أقصى عمر للمشروع بالدقائق منذ نشره (المشاريع الأقدم يتم تجاهلها بمجرد الوصول لها في القائمة)
MAX_PROJECT_AGE_MINUTES=15

# الحد الأدنى لمعدل توظيف العميل (%)
MIN_EMPLOYMENT_RATE=30

# قبول العملاء الجدد (الذين لم يُحسب لهم معدل توظيف بعد)
ACCEPT_NEW_CLIENTS=true

# وضع التشغيل: once أو cron (cron = يعمل بشكل دوري ولا يتوقف)
RUN_MODE=cron

# جدول التشغيل الدوري (صيغة cron) - كل 5 دقائق حسب طلبك
CRON_SCHEDULE=*/5 * * * *

# مهلة بين كل طلب وآخر (مللي ثانية) لتجنب الحظر
DELAY_BETWEEN_REQUESTS_MS=1500

# --- إعدادات إشعارات تيليجرام ---
# التوكن الذي تحصل عليه من @BotFather بعد إنشاء بوت جديد
TELEGRAM_BOT_TOKEN=

# الـ Chat ID الخاص بك (راجع README لمعرفة كيفية الحصول عليه)
TELEGRAM_CHAT_ID=
